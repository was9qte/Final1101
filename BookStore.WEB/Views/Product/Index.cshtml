@model List<BookStore.Web.Models.Product>

@{
    ViewBag.Title = "Товары";
}

<h2>Товары</h2>

@foreach (var item in Model)
{
    <div style="border:1px solid #DAA520;
                padding:15px;
                margin:10px;
                border-radius:5px;">

        <h3>@item.Name</h3>

        <p>@item.Description</p>

        <p>
            <b>Производитель:</b>
            @item.Author
        </p>

        <p>
            <b>Цена:</b>
            @item.Price
        </p>

        <a href="/Product/Order/@item.Id"
           style="padding:8px 15px;
                  background:#B8860B;
                  color:white;
                  text-decoration:none;
                  border-radius:4px;">
            Заказать
        </a>

    </div>
}