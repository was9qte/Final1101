<Window x:Class="Itogovaya_rabota.CartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Itogovaya_rabota"
        mc:Ignorable="d"
        Title="Корзина"
        Icon="Resources/icon.ico"
        FontFamily="Calibri"
        Background="#FFFFFF"
        Height="450"
        Width="800"
        MinWidth="1000"
        MinHeight="600"
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DataGrid x:Name="CartDataGrid"
                  AutoGenerateColumns="False"
                  CellEditEnding="CartDataGrid_CellEditEnding"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  TabIndex="0">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Книга"
                                    Binding="{Binding Product.Name}"
                                    Width="250"/>

                <DataGridTextColumn Header="Цена"
                                    Binding="{Binding Product.Price}"
                                    Width="100"/>

                <DataGridTextColumn Header="Количество"
                                    Binding="{Binding Quantity, Mode=TwoWay}"
                                    Width="100"/>

                <DataGridTextColumn Header="Сумма"
                                    Binding="{Binding TotalPrice}"
                                    Width="120"/>

            </DataGrid.Columns>

        </DataGrid>

        <Grid Grid.Row="1"
              Margin="0,10,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Удалить выбранный"
                    Background="#B8860B"
                    Foreground="#FFFFFF"
                    Height="35"
                    Margin="0,0,5,0"
                    Click="DeleteButton_Click"
                    TabIndex="1"/>

            <Button Grid.Column="1"
                    Content="Оформить заказ"
                    Background="#B8860B"
                    Foreground="#FFFFFF"
                    Height="35"
                    Margin="5,0,0,0"
                    Click="CheckoutButton_Click"
                    TabIndex="2"/>

        </Grid>

        <TextBlock x:Name="TotalTextBlock"
                   Grid.Row="1"
                   FontWeight="Bold"
                   FontSize="16"
                   Margin="0,0,0,50"/>

        <Button Grid.Row="2"
                Content="Назад"
                Height="35"
                Margin="0,10,0,0"
                Background="#B8860B"
                Foreground="#FFFFFF"
                Click="BackButton_Click"
                TabIndex="3"/>

    </Grid>

</Window>
