<Window x:Class="Itogovaya_rabota.OrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Itogovaya_rabota"
        mc:Ignorable="d"
        Title="Работа с заказами"
        Icon="Resources/icon.ico"
        FontFamily="Calibri"
        Background="#FFFFFF"
        Height="600"
        Width="1400"
        MinWidth="1000"
        MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">

            <TextBlock Text="Номер заказа:"
                       VerticalAlignment="Center"
                       FontWeight="Bold"/>

            <TextBox x:Name="OrderNumberTextBox"
                     Width="150"
                     Margin="5"
                     TabIndex="0"/>

            <Button Content="Найти"
                    Width="100"
                    Background="#B8860B"
                    Foreground="#FFFFFF"
                    FontWeight="Bold"
                    Click="FindButton_Click"
                    PreviewTextInput="OrderNumberTextBox_PreviewTextInput"
                    DataObject.Pasting="OrderNumberTextBox_Pasting"
                    TabIndex="1"/>

            <Button Content="Сбросить"
                    Width="100"
                    Margin="5,0,0,0"
                    Background="#B8860B"
                    Foreground="#FFFFFF"
                    FontWeight="Bold"
                    Click="ResetButton_Click"
                    TabIndex="4"/>

        </StackPanel>

        <DataGrid x:Name="OrdersDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  Background="#FFFFFF"
                  TabIndex="2">

            <DataGrid.Columns>

                <DataGridTextColumn Header="№ заказа"
                    Binding="{Binding OrderNumber}"
                    IsReadOnly="True"/>

                <DataGridTextColumn Header="Артикулы"
                    Binding="{Binding Articles}"
                    IsReadOnly="True"
                    Width="220"/>

                <DataGridTextColumn Header="Дата заказа"
                    Binding="{Binding OrderDate}"
                    IsReadOnly="True"/>

                <DataGridTextColumn Header="Дата доставки"
                    Binding="{Binding DeliveryDate}"/>

                <DataGridTextColumn Header="Клиент"
                    Binding="{Binding UserName}"
                    IsReadOnly="True"/>

                <DataGridComboBoxColumn Header="Статус"
                        SelectedValueBinding="{Binding StatusId}"
                        SelectedValuePath="Id"
                        DisplayMemberPath="Name"/>

            </DataGrid.Columns>

        </DataGrid>

        <Grid Grid.Row="2"
              Margin="0,10,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Назад"
                    Height="35"
                    Margin="0,0,5,0"
                    Background="#B8860B"
                    Foreground="#FFFFFF"
                    FontWeight="Bold"
                    Click="BackButton_Click"/>

            <Button Grid.Column="1"
                    Content="Сохранить изменения"
                    Height="35"
                    Margin="5,0,0,0"
                    Background="#B8860B"
                    Foreground="#FFFFFF"
                    FontWeight="Bold"
                    Click="SaveButton_Click"
                    TabIndex="3"/>

        </Grid>

    </Grid>

</Window>
