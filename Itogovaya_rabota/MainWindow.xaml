<Window x:Class="Itogovaya_rabota.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Itogovaya_rabota"
        mc:Ignorable="d"
        Title="Книжный магазин"
        Icon="Resources/icon.ico"
        Height="600"
        Width="1000"
        MinWidth="1250"
        MinHeight="600"
        FontFamily="Calibri"
        Background="#FFFFFF"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <Border Background="#DAA520"
                Height="90"
                DockPanel.Dock="Top">

            <Grid Margin="10">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <Image Source="Resources/icon.png"
                       Grid.Column="0"
                       Stretch="Uniform"/>

                <TextBlock Grid.Column="1"
                           Text="Книжный магазин"
                           FontSize="28"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

                <StackPanel Grid.Column="2"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                    <TextBlock x:Name="UserNameTextBlock"
                               Text="Гость"
                               FontWeight="Bold"
                               HorizontalAlignment="Right"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        
                        <Button x:Name="CartButton"
                                Content="Корзина"
                                Width="90"
                                Height="30"
                                Margin="5"
                                Background="#B8860B"
                                Foreground="#FFFFFF"
                                FontWeight="Bold"
                                Visibility="Collapsed"
                                Click="CartButton_Click"/>
                        
                        <Button x:Name="OrdersButton"
                                Content="Заказы"
                                Width="90"
                                Height="30"
                                Margin="5"
                                Background="#B8860B"
                                Foreground="#FFFFFF"
                                FontWeight="Bold"
                                Visibility="Collapsed"
                                Click="OrdersButton_Click"/>

                        <Button x:Name="LoginButton"
                                Content="Войти"
                                Width="90"
                                Height="30"
                                Margin="5"
                                Background="#B8860B"
                                Foreground="#FFFFFF"
                                FontWeight="Bold"
                                Click="LoginButton_Click"/>

                        <Button x:Name="LogoutButton"
                                Content="Выйти"
                                Width="90"
                                Height="30"
                                Margin="5"
                                Background="#B8860B"
                                Foreground="#FFFFFF"
                                FontWeight="Bold"
                                Visibility="Collapsed"
                                Click="LogoutButton_Click"/>

                    </StackPanel>

                </StackPanel>

            </Grid>

        </Border>   

        <Grid Margin="10">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="CountTextBlock"
                       Grid.Row="0"
                       Margin="0,0,0,10"
                       FontSize="14"
                       FontWeight="Bold"/>

            <WrapPanel Grid.Row="1"
                       Margin="0,0,0,10">

                <TextBlock Text="Поиск:"
                           VerticalAlignment="Center"
                           FontWeight="Bold"/>

                <TextBox x:Name="SearchTextBox"
                         Width="150"
                         Height="20"
                         Margin="5"
                         TabIndex="0"
                         TextChanged="FilterChanged"/>

                <TextBlock Text="Производитель:"
                           VerticalAlignment="Center"
                           FontWeight="Bold"/>

                <ComboBox x:Name="ManufacturerComboBox"
                          Width="150"
                          Height="20"
                          Margin="5"
                          TabIndex="1"
                          SelectionChanged="FilterChanged"/>

                <TextBlock Text="Цена от:"
                           VerticalAlignment="Center"
                           FontWeight="Bold"/>

                <TextBox x:Name="MinPriceTextBox"
                         Width="80"
                         Height="20"
                         Margin="5"
                         TabIndex="2"
                         TextChanged="FilterChanged"/>

                <TextBlock Text="до:"
                           VerticalAlignment="Center"
                           FontWeight="Bold"/>

                <TextBox x:Name="MaxPriceTextBox"
                         Width="80"
                         Height="20"
                         Margin="5"
                         TabIndex="3"
                         TextChanged="FilterChanged"/>

                <TextBlock Text="Сортировка:"
                           VerticalAlignment="Center"
                           FontWeight="Bold"/>

                <ComboBox x:Name="SortComboBox"
                          Width="180"
                          Height="20"
                          Margin="5"
                          TabIndex="4"
                          SelectionChanged="FilterChanged">

                    <ComboBoxItem Content="Без сортировки"/>
                    <ComboBoxItem Content="Название (A-Я)"/>
                    <ComboBoxItem Content="Название (Я-А)"/>
                    <ComboBoxItem Content="Цена (Возрастание)"/>
                    <ComboBoxItem Content="Цена (Убывание)"/>

                </ComboBox>

            </WrapPanel>

            <ListView x:Name="ProductsListView"
                      Grid.Row="2"
                      HorizontalContentAlignment="Stretch"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <ListView.ItemTemplate>

                    <DataTemplate>

                        <Border BorderBrush="#DAA520"
                                BorderThickness="2"
                                CornerRadius="5"
                                Margin="5"
                                Padding="10">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="{Binding Name}"
                                               FontSize="18"
                                               FontWeight="Bold"/>

                                    <TextBlock Grid.Row="1"
                                               Margin="0,5,10,5"
                                               Text="{Binding Description}"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="2">
                                <Run Text="Производитель: "/>
                                <Run Text="{Binding ManufacturerName}"/>
                                    </TextBlock>

                                    <TextBlock Grid.Row="3">
                                <Run Text="Цена: "/>
                                <Run Text="{Binding Price}"/>
                                    </TextBlock>

                                </Grid>

                                <Button Grid.Column="1"
                                        Width="120"
                                        Height="40"
                                        Margin="10,0,10,0"
                                        Background="#B8860B"
                                        Foreground="#FFFFFF"
                                        FontWeight="Bold"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Content="Заказать"
                                        Click="OrderButton_Click"/>

                            </Grid>

                        </Border>

                    </DataTemplate>

                </ListView.ItemTemplate>

            </ListView>

        </Grid>

    </DockPanel>

</Window>